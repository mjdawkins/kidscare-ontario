# Kidscare Ontario — Environment Variables
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored and never committed.

# Supabase
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Database (Prisma — connection string for PostgreSQL via Supabase)
# DATABASE_URL = transaction pooler (port 6543), used by Prisma Client at runtime
# DIRECT_URL = direct connection (port 5432), used by prisma migrate
DATABASE_URL=
DIRECT_URL=

# Google Places API (server-only — never prefix with NEXT_PUBLIC_)
# Used in cron jobs and API routes to fetch clinic hours/places data.
GOOGLE_MAPS_API_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Cron security — protect Vercel Cron Jobs endpoints
CRON_SECRET=
