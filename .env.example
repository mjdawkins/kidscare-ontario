# Kidscare Ontario — Environment Variables
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored and never committed.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Database (Prisma — connection string for PostgreSQL via Supabase)
DATABASE_URL=

# Google Places API (server-only — never prefix with NEXT_PUBLIC_)
# Used in cron jobs and API routes to fetch clinic hours/places data.
GOOGLE_MAPS_API_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Cron security — protect Vercel Cron Jobs endpoints
CRON_SECRET=
